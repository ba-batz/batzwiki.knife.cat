      <link>http://localhost:1313/medat-vokabel/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/medat-vokabel/</guid>
      <description>&lt;h2 id=&#34;zelle&#34;&gt;&lt;a href=&#34;http://localhost:1313/zelle&#34;&gt;Zelle&lt;/a&gt;&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Wort&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Herkunft&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Bedeutung&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Beispiel&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Prokaryote&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;pro (vor) + karyon (Kern)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zelle ohne Zellkern&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Bakterien&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Euzyte&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;eu (gut,echt) + karyon&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zelle mit Zellkern&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Nervenzelle&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Nukleoid&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;nukleos (Kern) + oeides (ähnlich,artig)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zellkern&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Chromosom&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;chroma (Farbe) + soma (Körper)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Träger von DNS&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Plasmid&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;plasma (Gebilde,Form) + oedis&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Mitochondrium&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mitos (Faden) + chondrion (Korn)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Kraftwerk der Zelle&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Membran&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;membrana (Häutchen)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Lysosom&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;lysis (Auflösung) + soma&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;endoplasmatisches Retikulum&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;endon (immer) + plasma +  reticulum (kleines Netz)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;ER&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zystol&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;solutio (Lösung)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Kinozilie&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;kinein (bewegen) + cilium (Augenlied,Wimper)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Mikrovilli&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mikro (klein) + villi (zottiges Haar)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Lunge,Magen&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zentriol&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;kentrum (Mittelpunkt) + iol (chen)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Peroxisom&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;peroxid (H2O2)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Proteasom&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;protein (proton (der Erste))&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Zellnekrose&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;nekrosis (das Töten)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Apoptose&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Apoptosis (apo (weg) + ptosis (fallen))&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Metabolismus&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;metabolie (Umsetzung,Änderung,Übergang)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Desoxyribonnukleinsäure&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;de (ab,weg) + oxygenium (O2) + ribose (Zucker)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Erbgut&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;DNS,DNA&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Aminosäure&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;ammoniak (NH3)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Phospholipid&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;phosphor + lipos (fett) + oedis&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Heterochromatin&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;heteros (anders,ungleich) + chroma&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;HC&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;perinkuläres HC&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;peri (um&amp;hellip;herum) + nukleos&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;peripheres HC&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;periphereia (peri + phereia (tragen))&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Kernlamina&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;lamina (Platte,Blatt,Scheibe)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;ER-Lumen&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;lumen (Fenster)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;ER-Zisternen&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;cisterna (Wasser-,Sammelbehälter)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Vesikel&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;vesicula (Bläschen)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;</description>
    </item>
